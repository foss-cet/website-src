  <PageHead slot="head" title="About" />
  <Breadcrumbs items={[{ label: 'About', icon: 'lucide:info' }]} />
  <div class="mx-auto max-w-4xl">
    <section class="px-6 pt-24">
      <div class="hero-content mx-auto max-w-6xl text-center">
        <h1
          class="h-full py-4 font-mono text-4xl leading-none font-medium italic md:text-6xl"
        >
          foss<span class="text-primary">cet</span>
        </h1>
        <p
          class="text-muted-foreground mx-auto mt-6 mb-12 max-w-3xl text-xl leading-relaxed"
        >
          Building software freedom, one commit at a time.
        </p>
      </div>
    </section>

