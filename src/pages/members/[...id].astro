---
import BlogCard from '@/components/BlogCard.astro'
import Breadcrumbs from '@/components/Breadcrumbs.astro'
import MemberCard from '@/components/MemberCard.astro'
import PageHead from '@/components/PageHead.astro'
import Layout from '@/layouts/Layout.astro'
import { getAllMembers, getPostsByAuthor } from '@/lib/data-utils'
import { render } from 'astro:content'

export async function getStaticPaths() {
  const members = await getAllMembers()
  return members.map((member) => ({
    params: { id: member.id },
    props: { member },
  }))
}

const { member } = Astro.props
const memberPosts = await getPostsByAuthor(member.id)
const { Content } = await render(member)
---

<Layout class="max-w-3xl">
  <PageHead
    slot="head"
    title={`${member.data.name} (Member)`}
    description={member.data.bio || `Profile of ${member.data.name}.`}
    noindex
  />
  <Breadcrumbs
    items={[
      { href: '/members', label: 'Members', icon: 'lucide:users' },
      { label: member.data.name, icon: 'lucide:user' },
    ]}
  />

  <section
    class="my-5 grid grid-cols-1 grid-rows-2 justify-items-center gap-6 px-2 md:grid-cols-[16rem_1fr] md:grid-rows-1 md:px-0"
  >
    <MemberCard member={member} />
    <article class="prose">
      <Content />
    </article>
  </section>

  <section class="my-15 flex flex-col gap-y-4">
    <h2 class="text-2xl font-medium">Posts by {member.data.name}</h2>
    {
      memberPosts.length > 0 ? (
        <ul class="flex flex-col gap-4">
          {memberPosts
            .filter((post) => !post.data.draft)
            .map((post) => (
              <li>
                <BlogCard entry={post} />
              </li>
            ))}
        </ul>
      ) : (
        <p class="text-muted-foreground">
          No posts available from this member.
        </p>
      )
    }
  </section>
</Layout>
